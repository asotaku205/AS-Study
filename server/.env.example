# Server
NODE_ENV=production
PORT=3000
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=asstudy
DB_PASSWORD=your_password
DB_NAME=asstudy
# Bật true lần deploy đầu để tạo bảng, sau đó tắt
DB_SYNCHRONIZE=true

# JWT
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d
REFRESH_TOKEN_PEPPER=change_me_pepper_secret

# Google OAuth (tùy chọn)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# SMTP Email (tùy chọn)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Google Gemini AI
GEMINI_API_KEY=
